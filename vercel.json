{
  "rewrites": [
    { "source": "/", "destination": "/dashboard/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" }
  ],
  "headers": [
    {
      "source": "/dashboard/data.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
